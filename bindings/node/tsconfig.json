{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": true,
    "target": "ES2024"
  },
  "include": [
    "*.cjs",
    "*.d.cts",
    "index.d.ts",
    "test/**/*.cjs",
    "test/**/*.cts"
  ]
}
