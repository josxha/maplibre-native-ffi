#!/usr/bin/env python3
#MISE description="Regenerate the jextract symbol include argfile"

import os
import re
import subprocess
from pathlib import Path

IDENTIFIER = r"[A-Za-z_]\w*"
BLOCK_COMMENT = re.compile(r"/\*.*?\*/", re.DOTALL)
LINE_COMMENT = re.compile(r"//.*?$", re.MULTILINE)
FORWARD_STRUCT_TYPEDEF = re.compile(
    rf"\btypedef\s+struct\s+({IDENTIFIER})\s+({IDENTIFIER})\s*;"
)
NAMED_STRUCT_DEFINITION = re.compile(rf"\b(?:typedef\s+)?struct\s+({IDENTIFIER})\s*\{{")


def strip_c_comments(text: str) -> str:
    return LINE_COMMENT.sub("", BLOCK_COMMENT.sub("", text))


def find_opaque_struct_typedefs(include_root: Path) -> set[str]:
    forward_typedefs = {}
    defined_tags = set()

    for header in include_root.rglob("*.h"):
        text = strip_c_comments(header.read_text())
        for tag, alias in FORWARD_STRUCT_TYPEDEF.findall(text):
            forward_typedefs[alias] = tag
        defined_tags.update(NAMED_STRUCT_DEFINITION.findall(text))

    return {alias for alias, tag in forward_typedefs.items() if tag not in defined_tags}


def main() -> None:
    binding_dir = Path.cwd().resolve()
    root = binding_dir.parents[1]

    gradle = root / ("gradlew.bat" if os.name == "nt" else "gradlew")
    subprocess.run(
        [str(gradle), ":bindings:java-ffm:dumpMaplibreNativeCIncludes"],
        cwd=root,
        check=True,
    )

    dump = binding_dir / "build" / "reports" / "jextract" / "maplibreNativeC-includes.txt"
    output = binding_dir / "src" / "jextract" / "maplibre-native-c.includes"
    include_root = root / "include" / "maplibre_native_c"
    opaque_structs = find_opaque_struct_typedefs(include_root)
    include_line = re.compile(r"^(--include-\w+)\s+(\S+)\s+# header: (.+)$")
    sections: dict[str, set[tuple[str, str]]] = {}

    for line in dump.read_text().splitlines():
        match = include_line.match(line)
        if match is None:
            continue

        option, symbol, header = match.groups()
        header_path = Path(header).resolve()
        try:
            relative_header = header_path.relative_to(include_root)
        except ValueError:
            continue

        if symbol in opaque_structs:
            continue

        sections.setdefault(relative_header.as_posix(), set()).add((option, symbol))

    lines = [
        "# Generated by mise run //bindings/java-ffm:jextract:update-includes.",
        "# Keep declarations from include/maplibre_native_c/** only.",
        "",
    ]
    for header in sorted(sections):
        lines.append(f"# include/maplibre_native_c/{header}")
        for option, symbol in sorted(sections[header]):
            lines.append(f"{option} {symbol}")
        lines.append("")

    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text("\n".join(lines))


if __name__ == "__main__":
    main()
