#!/usr/bin/env bash
#MISE description="Run a quick command in the local devcontainer image."
set -euo pipefail

host_arch="$(uname -m)"
case "$host_arch" in
  arm64 | aarch64) platform="linux/arm64" ;;
  x86_64 | amd64) platform="linux/amd64" ;;
  *) echo "unsupported host architecture: $host_arch" >&2; exit 1 ;;
esac

mise run :build

docker run --rm \
  --platform "$platform" \
  --env EGL_PLATFORM=surfaceless \
  --env LIBGL_ALWAYS_SOFTWARE=true \
  maplibre-native-ffi-devcontainer:local \
  bash -lc 'mise --version && eval "$(mise activate bash)" && pixi --version && zig version && node --version'
