#!/usr/bin/env bash
set -euo pipefail

if [[ "${CI:-}" != "true" ]]; then
  exec mise run //:build
fi

found=false
for lib in "${MLN_FFI_BUILD_DIR:-build/host}"/libmaplibre-native-c.* build/libmaplibre-native-c.*; do
  if [[ -f "$lib" ]]; then
    found=true
    break
  fi
done

if [[ "$found" != "true" ]]; then
  echo "missing ${MLN_FFI_BUILD_DIR:-build/host}/libmaplibre-native-c.*; native artifact was not downloaded" >&2
  exit 1
fi
