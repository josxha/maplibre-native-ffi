#!/usr/bin/env -S uv run --script
#MISE description="Generate the GitHub Actions CI workflow from CI manifests."
# /// script
# dependencies = ["pydantic==2.13.4", "pyyaml==6.0.3"]
# ///

import argparse
import difflib
import pathlib
import re
import sys
import tomllib
from typing import Annotated

from pydantic import (
    BaseModel,
    ConfigDict,
    Field,
    ValidationError,
    ValidationInfo,
    field_validator,
    model_validator,
)
import yaml


REPO_ROOT = pathlib.Path(__file__).resolve().parents[3]
VARIANTS_PATH = REPO_ROOT / "ci" / "variants.toml"
SUBPROJECTS_DIR = REPO_ROOT / "ci" / "subprojects"
WORKFLOW_PATH = REPO_ROOT / ".github" / "workflows" / "ci.yml"

CHECKOUT_ACTION = "actions/checkout@df4cb1c069e1874edd31b4311f1884172cec0e10"
TASK_PATTERN = re.compile(r"^(?:[A-Za-z0-9_-]+|//[A-Za-z0-9_./-]+:[A-Za-z0-9_-]+)$")

NonEmptyString = Annotated[str, Field(min_length=1)]
NonEmptyStringList = Annotated[list[NonEmptyString], Field(min_length=1)]


class StrictManifestModel(BaseModel):
    model_config = ConfigDict(extra="forbid", strict=True)


class VariantConfig(StrictManifestModel):
    runner: NonEmptyString
    os: NonEmptyString
    arch: NonEmptyString
    backend: NonEmptyString
    supports_tests: bool = True


class Variant(VariantConfig):
    name: NonEmptyString


class VariantsManifest(StrictManifestModel):
    variants: Annotated[dict[NonEmptyString, VariantConfig], Field(min_length=1)]


class RequiresConfig(StrictManifestModel):
    os: NonEmptyStringList | None = None
    arch: NonEmptyStringList | None = None
    backend: NonEmptyStringList | None = None
    exclude: list[NonEmptyString] = Field(default_factory=list)

    @field_validator("os", "arch", "backend")
    @classmethod
    def require_known_values(
        cls, values: list[str] | None, info: ValidationInfo
    ) -> list[str] | None:
        if values is None:
            return values
        known_values = (info.context or {}).get("variant_values", {})
        unknown = set(values) - known_values.get(info.field_name, set())
        if unknown:
            raise ValueError(f"unknown values: {sorted(unknown)}")
        return values

    @field_validator("exclude")
    @classmethod
    def require_known_variants(
        cls, variants: list[str], info: ValidationInfo
    ) -> list[str]:
        known_variants = (info.context or {}).get("variants", set())
        unknown = set(variants) - known_variants
        if unknown:
            raise ValueError(f"unknown variants: {sorted(unknown)}")
        return variants


class CiConfig(StrictManifestModel):
    build: NonEmptyString | None = None
    test: NonEmptyString | None = None
    run: NonEmptyString | None = None

    @model_validator(mode="after")
    def require_action(self) -> "CiConfig":
        if self.build is None and self.test is None and self.run is None:
            raise ValueError("[ci] must contain at least one action")
        return self

    @field_validator("build", "test", "run")
    @classmethod
    def require_task_name(cls, task: str | None) -> str | None:
        if task is not None and not TASK_PATTERN.fullmatch(task):
            raise ValueError("must be a mise task name")
        return task


class SubprojectManifest(StrictManifestModel):
    requires: RequiresConfig = Field(default_factory=RequiresConfig)
    ci: CiConfig


def parse_model[T: BaseModel](
    path: pathlib.Path, model: type[T], context: dict | None = None
) -> T:
    try:
        with path.open("rb") as file:
            return model.model_validate(tomllib.load(file), context=context)
    except ValidationError as error:
        raise SystemExit(f"error: {path}: {error}") from None


def load_variants() -> list[Variant]:
    manifest = parse_model(VARIANTS_PATH, VariantsManifest)
    return [
        Variant(name=name, **config.model_dump())
        for name, config in manifest.variants.items()
    ]


def matches(variant: Variant, requires: dict[str, list[str]]) -> bool:
    return all(getattr(variant, key) in values for key, values in requires.items())


def load_commands(variants: list[Variant]) -> dict[str, list[str]]:
    context = {
        "variants": {variant.name for variant in variants},
        "variant_values": {
            "os": {variant.os for variant in variants},
            "arch": {variant.arch for variant in variants},
            "backend": {variant.backend for variant in variants},
        },
    }
    commands = {variant.name: [] for variant in variants}

    paths = sorted(
        SUBPROJECTS_DIR.glob("*.toml"),
        key=lambda path: (path.name != "native.toml", path.name),
    )
    for path in paths:
        manifest = parse_model(path, SubprojectManifest, context)
        is_native = path.name == "native.toml"
        requires = manifest.requires.model_dump(
            include={"os", "arch", "backend"}, exclude_none=True
        )
        excluded_variants = set(manifest.requires.exclude)
        tasks = manifest.ci.model_dump(exclude_none=True)

        for variant in variants:
            if not matches(variant, requires) or variant.name in excluded_variants:
                continue
            for action_key, task in tasks.items():
                build_only_native = variant.os in {"android", "ios", "ohos"}
                if is_native and not build_only_native and action_key == "build":
                    continue
                if action_key == "test" and not variant.supports_tests:
                    continue
                commands[variant.name].append(f"mise run {task}")

    return commands


def variant_job_id(variant: Variant) -> str:
    return f"variant-{variant.name}"


def checkout_step(*, persist_credentials: bool = False) -> dict[str, object]:
    step: dict[str, object] = {"uses": CHECKOUT_ACTION}
    if not persist_credentials:
        step["with"] = {"persist-credentials": False}
    return step


def setup_steps(*, persist_credentials: bool = False) -> list[dict[str, object]]:
    return [
        checkout_step(persist_credentials=persist_credentials),
        {"uses": "./.github/actions/setup-ci-deps"},
    ]


class LiteralString(str):
    pass


class WorkflowDumper(yaml.SafeDumper):
    def increase_indent(self, flow: bool = False, indentless: bool = False) -> None:
        return super().increase_indent(flow, False)


def represent_literal_string(dumper: yaml.Dumper, data: LiteralString) -> yaml.Node:
    return dumper.represent_scalar("tag:yaml.org,2002:str", data, style="|")


WorkflowDumper.add_representer(LiteralString, represent_literal_string)


def render_workflow(variants: list[Variant], commands: dict[str, list[str]]) -> str:
    jobs = {
        "hygiene": {
            "name": "hygiene",
            "runs-on": "ubuntu-latest",
            "timeout-minutes": 30,
            "steps": [
                *setup_steps(),
                {"run": "mise run ci:lint"},
            ],
        },
        "docs": {
            "name": "docs",
            "runs-on": "ubuntu-latest",
            "timeout-minutes": 60,
            "steps": [
                *setup_steps(),
                {"run": "mise run //docs:build"},
            ],
        },
    }

    for variant in variants:
        variant_commands = commands[variant.name]

        jobs[variant_job_id(variant)] = {
            "name": f"variant / {variant.name}",
            "runs-on": variant.runner,
            "timeout-minutes": 120,
            "env": {"MISE_ENV": variant.name},
            "steps": [
                *setup_steps(),
                {"run": "mise run configure"},
                *({"run": command} for command in variant_commands),
            ],
        }

    jobs["required"] = {
        "name": "ci-required",
        "runs-on": "ubuntu-latest",
        "timeout-minutes": 5,
        "if": "${{ always() }}",
        "needs": [
            "hygiene",
            "docs",
            *(variant_job_id(variant) for variant in variants),
        ],
        "steps": [
            {
                "name": "Fail if required jobs failed",
                "if": "${{ contains(needs.*.result, 'failure') || contains(needs.*.result, 'cancelled') || contains(needs.*.result, 'skipped') }}",
                "run": LiteralString("echo '${{ toJSON(needs) }}'\nexit 1\n"),
            },
            {"run": "true"},
        ],
    }

    workflow = {
        "name": "CI",
        "on": {
            "push": {"branches": ["main"]},
            "pull_request": {"branches": ["main"]},
        },
        "permissions": {"contents": "read"},
        "concurrency": {
            "group": "${{ github.workflow }}-${{ github.event.pull_request.number || github.ref }}",
            "cancel-in-progress": "${{ github.event_name == 'pull_request' }}",
        },
        "jobs": jobs,
    }
    rendered = yaml.dump(
        workflow,
        Dumper=WorkflowDumper,
        default_flow_style=False,
        sort_keys=False,
        width=4096,
    )
    return f"# Generated by `mise run ci:generate-workflow`. Do not edit directly.\n{rendered}"


def check_workflow(expected: str) -> int:
    actual = WORKFLOW_PATH.read_text() if WORKFLOW_PATH.exists() else ""
    if actual == expected:
        return 0
    diff = difflib.unified_diff(
        actual.splitlines(keepends=True),
        expected.splitlines(keepends=True),
        fromfile=str(WORKFLOW_PATH),
        tofile=f"{WORKFLOW_PATH} (generated)",
    )
    sys.stderr.writelines(diff)
    return 1


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--check", action="store_true", help="fail if the workflow is not up to date"
    )
    args = parser.parse_args()

    variants = load_variants()
    commands = load_commands(variants)
    rendered = render_workflow(variants, commands)

    if args.check:
        return check_workflow(rendered)

    WORKFLOW_PATH.write_text(rendered)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
