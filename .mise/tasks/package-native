#!/usr/bin/env python3
# MISE description="Install and archive the active native variant."

import os
import pathlib
import shutil
import subprocess
import sys
import tarfile


def required_env(name: str) -> str:
    value = os.environ.get(name)
    if not value:
        raise SystemExit(f"{name} is required")
    return value


def git(repo_root: pathlib.Path, *args: str) -> str:
    return subprocess.check_output(
        ["git", "-C", str(repo_root), *args],
        encoding="utf-8",
    ).strip()


def run(command: list[str], *, env: dict[str, str] | None = None) -> None:
    subprocess.run(command, check=True, env=env)


def update_macos_install_names(package_root: pathlib.Path) -> None:
    install_name_tool = shutil.which("install_name_tool")
    if install_name_tool is None:
        return

    codesign = shutil.which("codesign")
    if codesign is None:
        raise SystemExit("codesign is required after editing macOS dylibs")

    for dylib in package_root.rglob("*.dylib"):
        run([install_name_tool, "-id", f"@rpath/{dylib.name}", str(dylib)])
        run([codesign, "--force", "--sign", "-", str(dylib)])


def find_strip_tool() -> str:
    for name in ("strip", "llvm-strip"):
        path = shutil.which(name)
        if path is not None:
            return path
    raise SystemExit("strip (or llvm-strip) is required on Linux")


def strip_shared_libraries(package_root: pathlib.Path) -> None:
    if not sys.platform.startswith("linux"):
        return

    strip = find_strip_tool()
    for shared_library in package_root.rglob("*.so*"):
        run([strip, "--strip-debug", str(shared_library)])


def archive_package(
    package_parent: pathlib.Path, package_name: str, archive: pathlib.Path
) -> None:
    archive.unlink(missing_ok=True)
    with tarfile.open(archive, "w:gz") as tar:
        tar.add(package_parent / package_name, arcname=package_name, recursive=True)


def main() -> int:
    build_dir = pathlib.Path(required_env("MLN_FFI_BUILD_DIR"))
    variant = required_env("MISE_ENV")
    repo_root = pathlib.Path(
        os.environ.get("MLN_FFI_REPO_ROOT")
        or git(pathlib.Path.cwd(), "rev-parse", "--show-toplevel")
    )

    if not (build_dir / "cmake_install.cmake").is_file():
        print(f"Missing configured native build tree: {build_dir}", file=sys.stderr)
        print("Run mise run build before packaging.", file=sys.stderr)
        return 1

    package_name = f"maplibre-native-c-{variant}"
    package_parent = repo_root / "build" / "packages" / "native" / variant
    package_root = package_parent / package_name
    dist_dir = repo_root / "build" / "packages" / "native" / "dist"

    shutil.rmtree(package_root, ignore_errors=True)
    package_root.mkdir(parents=True)
    dist_dir.mkdir(parents=True, exist_ok=True)

    run(["cmake", "--install", str(build_dir), "--prefix", str(package_root)])
    update_macos_install_names(package_root)
    strip_shared_libraries(package_root)

    archive = dist_dir / f"{package_name}.tar.gz"
    archive_package(package_parent, package_name, archive)
    print(archive)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
