#!/usr/bin/env bash
#MISE description="Install and launch the Swift map iOS simulator app."
set -euo pipefail

if [[ "$MISE_ENV" != ios-simulator-* ]]; then
  exec mise -E ios-simulator-arm64-metal run //examples/swift-map:run:ios-simulator
fi

mise run package:ios-simulator

device=${MLN_FFI_IOS_SIMULATOR_DEVICE:-}
if [[ -z "$device" ]]; then
  device=$(
    xcrun simctl list devices available iOS |
      awk -F '[()]' '/ iPhone / && /Booted/ { print $2; exit }'
  )
fi
if [[ -z "$device" ]]; then
  echo "No booted iOS simulator device found. Open Simulator or set MLN_FFI_IOS_SIMULATOR_DEVICE." >&2
  exit 1
fi

state=$(
  xcrun simctl list devices "$device" |
    awk -F '[()]' -v id="$device" '$0 ~ id { print $4; exit }'
)
if [[ "$state" != "Booted" ]]; then
  echo "iOS simulator device is not booted: $device" >&2
  exit 1
fi

app_dir=".build/$MISE_ENV/SwiftMapIOS.app"
xcrun simctl install "$device" "$app_dir"
xcrun simctl launch --terminate-running-process \
  "$device" \
  org.maplibre.nativeffi.examples.swift-map-ios
